<Window x:Class="VulcansTrace.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VulcansTrace.Wpf.ViewModels"
        xmlns:val="clr-namespace:VulcansTrace.Wpf.Validation"
        Title="VulcansTrace" Height="720" Width="1200">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <LinearGradientBrush x:Key="AdvisorBubbleBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#f6f9ff" Offset="0"/>
            <GradientStop Color="#e3edfb" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="BadgeNeutralBrush" Color="#eef2f7"/>
        <SolidColorBrush x:Key="BadgeHighBrush" Color="#fff3e0"/>
        <SolidColorBrush x:Key="BadgeWarnBrush" Color="#fff8e1"/>
        <SolidColorBrush x:Key="BadgeErrorBrush" Color="#ffebee"/>
        <SolidColorBrush x:Key="WarningPanelBrush" Color="#fff8e1"/>
        <SolidColorBrush x:Key="WarningBorderBrush" Color="#ffe0b2"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#666666"/>
        <SolidColorBrush x:Key="RowAltBrush" Color="#f5f5f5"/>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#f9f9f9"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#222"/>
            <Setter Property="Background" Value="#e6e6e6"/>
            <Setter Property="BorderBrush" Value="#c5c5c5"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#dcdcdc"/>
                                <Setter Property="BorderBrush" Value="#b3b3b3"/>
                                <Setter Property="Foreground" Value="#222"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SeverityChip" TargetType="Border">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#334"/>
            <Setter Property="Background" Value="#eef2f7"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Severity}" Value="Info">
                    <Setter Property="Background" Value="#e3f2fd"/>
                    <Setter Property="BorderBrush" Value="#90caf9"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="Low">
                    <Setter Property="Background" Value="#e8f5e9"/>
                    <Setter Property="BorderBrush" Value="#a5d6a7"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="Medium">
                    <Setter Property="Background" Value="#fff8e1"/>
                    <Setter Property="BorderBrush" Value="#ffecb3"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="High">
                    <Setter Property="Background" Value="#ffebee"/>
                    <Setter Property="BorderBrush" Value="#ef9a9a"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="Critical">
                    <Setter Property="Background" Value="#fce4ec"/>
                    <Setter Property="BorderBrush" Value="#f48fb1"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="5*"/>
        </Grid.ColumnDefinitions>

        <!-- Summary and warnings -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Vertical" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6" HorizontalAlignment="Left">
                <Border Background="#eef2f7" Padding="8,4" CornerRadius="6" Margin="0,0,8,0">
                    <TextBlock>
                    <Run Text="Findings: "/><Run Text="{Binding Findings.FindingsCount, Mode=OneWay}" FontWeight="Bold"/>
                    </TextBlock>
                </Border>
                <Border Background="#fff3e0" Padding="8,4" CornerRadius="6" Margin="0,0,8,0">
                    <TextBlock>
                        <Run Text="High/Critical: "/><Run Text="{Binding Findings.HighCriticalCount, Mode=OneWay}" FontWeight="Bold"/>
                    </TextBlock>
                </Border>
                <Border Background="#fff8e1" Padding="8,4" CornerRadius="6" Margin="0,0,8,0">
                    <TextBlock>
                        <Run Text="Warnings: "/><Run Text="{Binding Findings.WarningCount, Mode=OneWay}" FontWeight="Bold"/>
                    </TextBlock>
                </Border>
                <Border Background="#ffebee" Padding="8,4" CornerRadius="6">
                    <TextBlock>
                        <Run Text="Parse Errors: "/><Run Text="{Binding Findings.ParseErrorCount, Mode=OneWay}" FontWeight="Bold"/>
                    </TextBlock>
                </Border>
            </StackPanel>
            <Border Background="#fff8e1"
                    BorderBrush="#ffe0b2"
                    BorderThickness="1"
                    Padding="8"
                    CornerRadius="6"
                    Visibility="{Binding Findings.HasWarnings, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Warnings detected during analysis:" FontWeight="Bold" />
                    <ItemsControl ItemsSource="{Binding Findings.Warnings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="* " Foreground="DarkOrange"/>
                                    <Run Text="{Binding}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
            <Border Background="#ffebee"
                    BorderBrush="#ef9a9a"
                    BorderThickness="1"
                    Padding="8"
                    CornerRadius="6"
                    Visibility="{Binding Findings.HasParseErrors, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Parse errors detected in the log:" FontWeight="Bold" />
                    <ItemsControl ItemsSource="{Binding Findings.ParseErrors}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock TextWrapping="Wrap">
                                    <Run Text="* " Foreground="Red"/>
                                    <Run Text="{Binding}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Left: bot + controls -->
        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,0">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <!-- Bot avatar -->
                <Image Width="48"
                       Height="48"
                       Margin="0,0,12,0"
                       Source="pack://application:,,,/Assets/VulcansTraceAvatar.png"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       SnapsToDevicePixels="True">
                    <Image.Clip>
                        <EllipseGeometry RadiusX="24" RadiusY="24" Center="24,24" />
                    </Image.Clip>
                </Image>
                <TextBlock Text="{Binding BotIntroText}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           Width="260"/>
            </StackPanel>
            <Grid Margin="12,0,0,12" Visibility="{Binding HasAdvisorMessage, Converter={StaticResource BoolToVisibility}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Background="{StaticResource AdvisorBubbleBrush}"
                        BorderBrush="#c3d3ea"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="8"
                        Width="280"
                        HorizontalAlignment="Left">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Tip:" FontWeight="Bold" Margin="0,0,6,0" VerticalAlignment="Top"/>
                        <TextBlock Grid.Column="1" Text="{Binding AdvisorMessage}" TextWrapping="Wrap"/>
                    </Grid>
                </Border>

                <Polygon Points="0,0 0,12 12,6"
                         Fill="#eaf1fc"
                         Stroke="#c3d3ea"
                         StrokeThickness="1"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Top"
                         Margin="12,60,0,0"/>
            </Grid>

            <TextBlock Text="Scan intensity:" FontWeight="Bold"/>
            <ComboBox ItemsSource="{Binding Intensities}"
                      SelectedItem="{Binding SelectedIntensity}"
                      Margin="0,4,0,4"/>

            <Expander Header="Advanced" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                        <TextBlock Text="Port scan max events/source (0 = unbounded):"
                                   VerticalAlignment="Center"
                                   Width="260"/>
                        <TextBox Width="80"
                                 VerticalAlignment="Center">
                        <TextBox.Text>
                            <Binding Path="PortScanMaxEntriesPerSource" UpdateSourceTrigger="PropertyChanged" NotifyOnValidationError="True" ValidatesOnExceptions="True">
                                <Binding.ValidationRules>
                                    <val:NonNegativeIntValidationRule />
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>
                    </StackPanel>
                </StackPanel>
            </Expander>

            <TextBlock Text="Paste Windows Firewall log:" FontWeight="Bold"/>
            <Grid Margin="0,4,0,8">
                <TextBox Text="{Binding LogText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Height="260"/>
                <TextBlock Text="Paste or type firewall log lines here..."
                           Foreground="#888"
                           Margin="6,6,0,0"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LogText}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,8,0,8">
                <Button Content="Analyze"
                        Width="100"
                        Margin="0,0,8,0"
                        Command="{Binding AnalyzeCommand}"/>

                <Button Content="Cancel"
                        Width="100"
                        Margin="0,0,8,0"
                        Command="{Binding CancelCommand}"/>

                <Button x:Name="ExportButton"
                        Content="Export Evidence"
                        Width="130"
                        Command="{Binding Evidence.ExportEvidenceCommand}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,4"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                <ProgressBar Height="6"
                             Width="140"
                             IsIndeterminate="True"
                             VerticalAlignment="Center"/>
                <TextBlock Text="Working..." Margin="8,0,0,0" VerticalAlignment="Center" Foreground="#444"/>
            </StackPanel>

            <StackPanel Orientation="Vertical" Margin="0,0,0,8">
                <TextBlock Text="Session HMAC Key (masked; copy to view):" FontWeight="Bold" FontSize="10" Foreground="Gray"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Evidence.MaskedSigningKey}" FontSize="10" Foreground="Gray" Margin="0,0,8,0"/>
                    <Button Content="Copy signing key" Command="{Binding Evidence.CopySigningKeyCommand}" FontSize="10" Padding="6,2" ToolTip="Copies full signing key to clipboard"/>
                </StackPanel>
            </StackPanel>

            <TextBlock Text="{Binding SummaryText}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Right: findings and errors tabs -->
        <TabControl Grid.Row="1" Grid.Column="1" Margin="0">
            <TabItem Header="Findings">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                        <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Text="{Binding Findings.SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="200" 
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="Severity filter:" VerticalAlignment="Center" Margin="12,0,4,0"/>
                        <ComboBox ItemsSource="{Binding Findings.SeverityFilters}"
                                  SelectedItem="{Binding Findings.SelectedSeverityFilter}"
                                  Width="170"
                                  VerticalAlignment="Center"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Findings.ItemsView}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="*"/>
                            <DataGridTemplateColumn Header="Severity" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource SeverityChip}">
                                            <TextBlock Text="{Binding Severity}" FontWeight="Bold" />
                                        </Border>

                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Source" Binding="{Binding SourceHost}" Width="*"/>
                            <DataGridTextColumn Header="Target" Binding="{Binding Target}" Width="*"/>
                            <DataGridTextColumn Header="Start" Binding="{Binding TimeStart}" Width="*"/>
                            <DataGridTextColumn Header="End" Binding="{Binding TimeEnd}" Width="*"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding ShortDescription}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Parse Errors">
                <ListBox ItemsSource="{Binding Findings.ParseErrors}" 
                         BorderThickness="0"
                         Foreground="Red"
                         FontFamily="Consolas"/>
            </TabItem>
            <TabItem Header="Warnings">
                <ListBox ItemsSource="{Binding Findings.Warnings}"
                         BorderThickness="0"
                         Foreground="DarkOrange"
                         FontFamily="Consolas"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
